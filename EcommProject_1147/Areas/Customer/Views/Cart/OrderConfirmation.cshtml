@model int
<div class="container row">
    <div class="col-12 text-center">
        <h1 class="text-primary text-center">Order Submitted Successfully</h1><br />
        <img src="~/images/Order.jpg" width="50%" />
    </div>
    <div class="col-12 text-center" style="color:green">
        <br />
        Thank you for Your Order!<br />
        We have received your Order and will Send you a Follow Up Email Shortly!!
        <br />
        Your Order Number is:@Model
    </div>
    <div class="col-6 text-right">
        <a asp-area="Customer" asp-controller="Home" asp-action="Index" class="btn btn-outline-info btn-sm">Continue Shopping</a>
    </div>
</div>

